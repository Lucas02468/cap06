<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="#FFFFFF"
    tools:context=".MainActivity">

    <!-- Título "ListaDeCompras" -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ListaDeCompras"
        android:textSize="20sp"
        android:textColor="#000000"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="24dp"/>

    <!-- Campo de entrada do produto -->
    <EditText
        android:id="@+id/txt_produto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Digite o nome do produto"
        android:inputType="text"
        android:padding="12dp"/>

    <!-- Botão "INSERTR" -->
    <Button
        android:id="@+id/btn_inserir"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="INSERTR"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:backgroundTint="#6200EE"
        android:textColor="#FFFFFF"
        android:layout_marginTop="16dp"
        android:padding="12dp"/>

    <!-- Lista de produtos -->
    <ListView
        android:id="@+id/list_view_produtos"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp"
        android:divider="#CCCCCC"
        android:dividerHeight="1dp"/>

</LinearLayout>